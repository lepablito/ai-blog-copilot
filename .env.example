# Copy to .env and fill in. Real environment variables take precedence over
# this file, so an exported GEMINI_API_KEY wins over whatever is written here.

# --- Tier 1: Gemini (primary) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Tier 2: NVIDIA NIM (OpenAI-compatible) ---
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# --- Tier 3: Ollama (local fallback, no key needed) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:30b-a3b

# Restrict the chain to a single tier — useful for testing one provider in
# isolation without spending API credits. Values: gemini | nim | ollama
LLM_ONLY=

# --- Reddit (optional but recommended) ---
# Without these the radar falls back to old.reddit's public .rss listing, which
# carries titles but no score or comment count — so Reddit posts cannot be
# ranked by traction. The unauthenticated /hot.json endpoint is not an option:
# it returns 403 to every client regardless of User-Agent.
#
# Create a free "script" app at https://www.reddit.com/prefs/apps
#   client_id = the string shown under the app name
#   secret    = the "secret" field
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional: path to the professional-portfolio checkout. Only read, never
# written — used to validate `relatedProject` slugs on export.
PORTFOLIO_PATH=
