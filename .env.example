# Copy to .env and fill in. Real environment variables take precedence over
# this file, so an exported GEMINI_API_KEY wins over whatever is written here.

# --- Tier 1: NVIDIA NIM (primary, OpenAI-compatible) ---
# Leads the chain: its free tier is far more generous than Gemini's 20/day.
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# --- Tier 2: Gemini (reserve) ---
# Held back rather than led with: 20 requests a day is about two radar passes.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Tier 3: Ollama (local floor, no key needed) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:30b-a3b

# Restrict the chain to a single tier — useful for testing one provider in
# isolation without spending API credits. Values: gemini | nim | ollama
LLM_ONLY=

# Note: there is deliberately no Reddit configuration here. See the README —
# Reddit is not a source for this project.

# Optional: path to the professional-portfolio checkout. Only read, never
# written — used to validate `relatedProject` slugs on export.
PORTFOLIO_PATH=
