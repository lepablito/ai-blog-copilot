      "PowerShell(python -m radar.run*)",
      "PowerShell(git status*)",
      "PowerShell(git diff*)",
      "PowerShell(git log*)",
      "PowerShell(git show*)",
      "PowerShell(git branch*)",
      "PowerShell(gh auth status*)",
      "PowerShell(gh repo view*)",
